rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
       return request.auth != null;
    }
    
    function isCHW(chwId) {
       return isAuthenticated() && request.auth.uid == chwId;
    }

    match /mothers/{motherId} {
      // Allow a CHW to read and write mothers assigned to them
      allow read: if isAuthenticated() && resource.data.chwId == request.auth.uid;
      
      // For creating, ensure the CHW is assigning themselves
      allow create: if isAuthenticated() && request.resource.data.chwId == request.auth.uid;
      
      // For updating, ensure the CHW is the one assigned
      allow update: if isAuthenticated() && resource.data.chwId == request.auth.uid && request.resource.data.chwId == request.auth.uid;
      
      // For deleting
      allow delete: if isAuthenticated() && resource.data.chwId == request.auth.uid;
    }
  }
}
